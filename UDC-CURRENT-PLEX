#!/bin/bash
# v7.0-PLEX - Optimized for Plex Media Server Maintenance
# Inherits all safety fixes from UDC v7.0 + Plex-specific logic

# --- Configuration ---
LOG_DIR="/home/logs"
UDC_LOG_DIR="$LOG_DIR/UDC"
RKHUNTER_LOG_DIR="$LOG_DIR/rkhunter"
CLAMAV_LOG_DIR="$LOG_DIR/clamav"
ERROR_LOG_DIR="$UDC_LOG_DIR/UDC-ERRORS"
SCRIPT_URL="https://github.com/mmedia13/UDC/raw/main/UDC-CURRENT-PLEX"
KEEP_KERNELS=2

# Plex Paths (Standard Ubuntu/Debian)
PLEX_USER="plex"
PLEX_DATA_DIR="/var/lib/plexmediaserver"
PLEX_CACHE_DIR="$PLEX_DATA_DIR/Library/Application Support/Plex Media Server/Cache"
PLEX_TRANSCODE_DIR="$PLEX_CACHE_DIR/TranscodedVideo"
PLEX_LOG_DIR="$PLEX_DATA_DIR/Library/Application Support/Plex Media Server/Logs"

# Create log directories if they don't exist
mkdir -p "$UDC_LOG_DIR" "$RKHUNTER_LOG_DIR" "$CLAMAV_LOG_DIR" "$ERROR_LOG_DIR"

# Set log file paths
DATE_STR=$(date +%m.%d.%y)
TIME_STR=$(date +%H.%M.%S)
LOGFILE="$UDC_LOG_DIR/UpdateNClean.log-$DATE_STR"
LOGFILE2="$RKHUNTER_LOG_DIR/RKhunter.log-$DATE_STR"
LOGFILE3="$CLAMAV_LOG_DIR/ClamAV.log-$DATE_STR"
ERRORLOG="$ERROR_LOG_DIR/UDC-ERROR-Log-${DATE_STR}_${TIME_STR}"

# --- Functions ---

log_error() {
    echo "[ERROR] $(date "+%T"): $1" >> "$ERRORLOG"
    echo "[ERROR] $(date "+%T"): $1" >&2
}

check_exit_status() {
    if [ $? -eq 0 ]; then
        echo "          ^ Process Completed ^" >> "$LOGFILE"
    else
        echo "          ^ [ERROR] Process Failed! ^" >> "$LOGFILE"
        log_error "Process failed (Exit Code: $?)"
    fi
}

# --- Plex Specific Functions ---

stop_plex() {
    echo "** Stopping Plex Media Server **"
    echo "$(date "+%T") : - Stopping Plex Service" >> "$LOGFILE"
    
    if command -v systemctl &>/dev/null; then
        if systemctl is-active --quiet plexmediaserver 2>/dev/null; then
            sudo systemctl stop plexmediaserver
            sleep 2 # Wait for graceful shutdown
            check_exit_status
        else
            echo "Plex service not active or not managed by systemd." >> "$LOGFILE"
        fi
    elif [ -f /etc/init.d/plexmediaserver ]; then
        sudo /etc/init.d/plexmediaserver stop
        sleep 2
        check_exit_status
    else
        echo "Could not find Plex service manager. Skipping stop." >> "$LOGFILE"
    fi
}

start_plex() {
    echo "** Starting Plex Media Server **"
    echo "$(date "+%T") : - Starting Plex Service" >> "$LOGFILE"
    
    if command -v systemctl &>/dev/null; then
        sudo systemctl start plexmediaserver
        check_exit_status
    elif [ -f /etc/init.d/plexmediaserver ]; then
        sudo /etc/init.d/plexmediaserver start
        check_exit_status
    else
        echo "Could not find Plex service manager. Skipping start." >> "$LOGFILE"
    fi
}

refresh_plex_metadata() {
    echo "** Refreshing Plex Metadata (Light Scan) **"
    echo "$(date "+%T") : - Triggering Metadata Refresh" >> "$LOGFILE"
    
    # Method 1: Try to trigger via API (requires Plex to be running and accessible)
    # Note: This is non-blocking. If Plex is just starting, this might fail, which is okay.
    if command -v curl &>/dev/null; then
        # Try localhost:32400
        if curl -s -o /dev/null -w "%{http_code}" http://localhost:32400/api > /dev/null 2>&1; then
            # Trigger a library refresh (this is a gentle refresh, not a full scan)
            # We send a signal to the Plex daemon to check for changes
            curl -s -X GET "http://localhost:32400/library/sections/all/refresh?X-Plex-Token=$(grep -oP '(?<=<token>)[^<]+' "$PLEX_DATA_DIR/Library/Application Support/Plex Media Server/Preferences.xml" 2>/dev/null || echo "")" > /dev/null 2>&1
            echo "Metadata refresh signal sent via API." >> "$LOGFILE"
        else
            echo "Plex API not reachable. Skipping API refresh. (Plex may still be starting)." >> "$LOGFILE"
        fi
    fi
    
    # Method 2: Force a database consistency check by restarting (already handled by start_plex)
    # The restart itself often triggers a quick consistency check.
    echo "Plex service restart will trigger internal consistency checks." >> "$LOGFILE"
}

clean_plex_transcodes() {
    echo "** Cleaning Stale Plex Transcodes **"
    echo "$(date "+%T") : - Scanning for stale transcodes" >> "$LOGFILE"
    
    if [ -d "$PLEX_TRANSCODE_DIR" ]; then
        # Find files older than 24 hours (1 day) in the transcode cache
        # This prevents deleting active streams while cleaning up stuck jobs
        STALE_COUNT=$(find "$PLEX_TRANSCODE_DIR" -type f -mtime +1 -delete 2>/dev/null | wc -l)
        
        if [ "$STALE_COUNT" -gt 0 ]; then
            echo "Removed $STALE_COUNT stale transcode files." >> "$LOGFILE"
        else
            echo "No stale transcode files found." >> "$LOGFILE"
        fi
        
        # Also check for zero-byte files (corrupt)
        ZERO_COUNT=$(find "$PLEX_TRANSCODE_DIR" -type f -size 0 -delete 2>/dev/null | wc -l)
        if [ "$ZERO_COUNT" -gt 0 ]; then
            echo "Removed $ZERO_COUNT zero-byte (corrupt) transcode files." >> "$LOGFILE"
        fi
    else
        echo "Transcode directory not found at $PLEX_TRANSCODE_DIR. Skipping." >> "$LOGFILE"
    fi
    check_exit_status
}

update_plex() {
    echo
    echo "** Updating Plex Media Server **"
    echo "$(date "+%T") : - Updating Plex" >> "$LOGFILE"

    if ! command -v plexmediaserver &>/dev/null && ! dpkg -l | grep -q plexmediaserver; then
        echo "Plex Media Server is not installed. Skipping update." >> "$LOGFILE"
        return
    fi

    # 1. Stop Plex
    stop_plex

    # 2. Update Package
    echo "Updating Plex package..." >> "$LOGFILE"
    sudo apt-get update
    sudo apt-get install --only-upgrade plexmediaserver -y
    check_exit_status

    # 3. Clean Stale Transcodes (while stopped)
    clean_plex_transcodes

    # 4. Start Plex
    start_plex

    # 5. Refresh Metadata
    refresh_plex_metadata

    echo "Plex update and maintenance complete." >> "$LOGFILE"
}

# --- System Update Functions (Inherited & Adapted) ---

update() {
    echo
    echo "** Update Time and Date **"
    echo "$(date "+%T") :   - Update Time and Date" >> "$LOGFILE"
    sudo ntpdate pool.ntp.org || log_error "ntpdate failed"
    check_exit_status

    echo
    echo "** Update package lists for upgrades **"
    echo "$(date "+%T") :   - Update package lists for upgrades" >> "$LOGFILE"
    sudo apt-get update
    check_exit_status

    echo
    echo "** Upgrade System to new release (if Available) **"
    echo "$(date "+%T") :   - Upgrade System to new release (if Available)" >> "$LOGFILE"
    if command -v do-release-upgrade &>/dev/null; then
        sudo do-release-upgrade -f DistUpgradeViewNonInteractive >> "$LOGFILE" 2>&1
        check_exit_status
    else
        echo "do-release-upgrade not found. Skipping release upgrade." >> "$LOGFILE"
    fi

    echo
    echo "** Updates packages and libraries **"
    echo "$(date "+%T") :   - Updates packages and libraries" >> "$LOGFILE"
    sudo apt-get full-upgrade -y
    check_exit_status

    echo
    echo "** Download and install packages as well as remove obsolete packages **"
    echo "$(date "+%T") :   - Download and install packages as well as remove obsolete packages" >> "$LOGFILE"
    sudo apt-get dist-upgrade -y
    check_exit_status

    echo
    echo "** Update Firefox Browser **"
    echo "$(date "+%T") :   - Update Firefox Browser" >> "$LOGFILE"
    sudo apt-get install firefox -y
    check_exit_status

    echo
    echo "** Finish configuration of partially installed packages **"
    echo "$(date "+%T") :   - Finish configuration of partially installed packages" >> "$LOGFILE"
    yes | sudo dpkg --configure -a
    check_exit_status

    echo
    echo "** Update ClamAV (if necessary) **"
    echo "$(date "+%T") :   - Updating ClamAV package..." >> "$LOGFILE"
    if command -v clamscan &>/dev/null; then
        sudo apt-get update
        sudo apt-get install --only-upgrade clamav clamav-daemon -y
        check_exit_status
    else
        echo "ClamAV is not installed. Skipping update." >> "$LOGFILE"
    fi

    echo
    echo "** Update virus database **"
    echo "$(date "+%T") :   - Update virus database" >> "$LOGFILE"
    if command -v freshclam &>/dev/null; then
        if systemctl is-active --quiet clamav-freshclam 2>/dev/null; then
            sudo systemctl stop clamav-freshclam
        elif [ -f /etc/init.d/clamav-freshclam ]; then
            sudo /etc/init.d/clamav-freshclam stop
        fi
        
        sudo freshclam
        check_exit_status

        if systemctl is-active --quiet clamav-freshclam 2>/dev/null; then
            sudo systemctl start clamav-freshclam
        elif [ -f /etc/init.d/clamav-freshclam ]; then
            sudo /etc/init.d/clamav-freshclam start
        fi
    else
        echo "freshclam not found. Skipping database update." >> "$LOGFILE"
    fi

    echo
    echo "** Update RKhunter **"
    echo "$(date "+%T") :   - Update RKhunter" >> "$LOGFILE"
    if command -v rkhunter &>/dev/null; then
        sudo rkhunter --update
        check_exit_status
        echo
        echo "** Update RKhunter database **"
        echo "$(date "+%T") :   - Update RKhunter Database" >> "$LOGFILE"
        sudo rkhunter --propupd
        check_exit_status
    else
        echo "rkhunter not found. Skipping." >> "$LOGFILE"
    fi
}

# --- Housekeeping Functions ---

housekeeping() {
    echo
    echo "$(date "+%m/%d/%Y @ %T") :   CLEANING" >> "$LOGFILE"
    echo "*--------------------------------------*"
    echo "*                                      *"
    echo "*            HOUSEKEEPING!            *"
    echo "*                                      *"
    echo "*--------------------------------------*"

    echo
    echo "** Clean up Kernels **"
    echo "$(date "+%T") :   - Purge old kernels" >> "$LOGFILE"

    CURRENT_KERNEL=$(uname -r)
    CURRENT_VER=$(echo "$CURRENT_KERNEL" | sed 's/-.*//')
    
    INSTALLED_KERNELS=$(dpkg -l 'linux-image-*' 'linux-headers-*' 2>/dev/null | awk '/^ii/ {print $2}' | sort -V -r)
    
    COUNT=0
    PURGE_LIST=""
    
    for KERNEL_PKG in $INSTALLED_KERNELS; do
        COUNT=$((COUNT + 1))
        PKG_VER=$(echo "$KERNEL_PKG" | sed -n 's/linux-image-\([0-9.]*\).*/\1/p' | sed -n 's/linux-headers-\([0-9.]*\).*/\1/p')
        
        if [ "$COUNT" -le "$KEEP_KERNELS" ]; then continue; fi
        if [ "$PKG_VER" = "$CURRENT_VER" ]; then continue; fi
        
        if dpkg -l "$KERNEL_PKG" &>/dev/null; then
            PURGE_LIST="$PURGE_LIST $KERNEL_PKG"
        fi
    done

    if [ -z "$PURGE_LIST" ]; then
        echo "No old kernels found for removal." >> "$LOGFILE"
    else
        echo "Removing old kernels: $PURGE_LIST" >> "$LOGFILE"
        sudo apt-get remove -y --purge $PURGE_LIST
        check_exit_status
    fi

    echo
    echo "** Remove unused config files **"
    if command -v deborphan &>/dev/null; then
        sudo deborphan -n --find-config | xargs -r sudo apt-get -y --purge autoremove >> "$LOGFILE" 2>&1
        check_exit_status
    else
        echo "deborphan not found. Skipping orphan check." >> "$LOGFILE"
    fi

    echo
    echo "** Clear local repository of retrieved package files **"
    echo "$(date "+%T") :   - Clear local repository" >> "$LOGFILE"
    sudo apt-get autoclean -y >> "$LOGFILE" 2>&1
    check_exit_status

    echo
    echo "** Uninstall unneeded packages and config files **"
    echo "$(date "+%T") :   - Autoremove unneeded packages" >> "$LOGFILE"
    sudo apt-get autoremove --purge -y >> "$LOGFILE" 2>&1
    check_exit_status

    echo
    echo "** Clear out local repository of downloaded package files **"
    echo "$(date "+%T") :   - Clean package cache" >> "$LOGFILE"
    sudo apt-get clean -y >> "$LOGFILE" 2>&1
    check_exit_status

    echo
    echo "** Completely purge previously installed packages and config files **"
    echo "$(date "+%T") :   - Purge rc packages" >> "$LOGFILE"
    RC_PACKAGES=$(dpkg -l | awk '/^rc/ { print $2 }')
    if [ -n "$RC_PACKAGES" ]; then
        sudo apt-get purge $RC_PACKAGES -y >> "$LOGFILE" 2>&1
        check_exit_status
    else
        echo "No rc packages to purge." >> "$LOGFILE"
    fi

    echo
    echo "** Scan for infected files and remove **"
    echo "$(date "+%T") :   - ClamAV Scan" >> "$LOGFILE"
    if command -v clamscan &>/dev/null; then
        # Exclude Plex cache to avoid scanning massive transcode files
        sudo clamscan -r --remove --infected --exclude-dir="$PLEX_CACHE_DIR" /home/ >> "$LOGFILE3" 2>&1
        check_exit_status
    else
        echo "ClamAV not found. Skipping scan." >> "$LOGFILE"
    fi

    echo
    echo "** Scan for Root Kits **"
    echo "$(date "+%T") :   - RKhunter Scan" >> "$LOGFILE"
    if command -v rkhunter &>/dev/null; then
        sudo rkhunter --check --sk >> "$LOGFILE2" 2>&1
        check_exit_status
    else
        echo "rkhunter not found. Skipping scan." >> "$LOGFILE"
    fi

    echo
    echo "** Remove Log Files older than 32 Days **"
    echo "$(date "+%T") :   - Cleanup old logs" >> "$LOGFILE"
    shopt -s nullglob
    OLD_LOGS=(/home/logs/*)
    if [ ${#OLD_LOGS[@]} -gt 0 ]; then
        find /home/logs -maxdepth 1 -type f -mtime +32 -delete >> "$LOGFILE" 2>&1
        find /home/logs -maxdepth 1 -type d -empty -delete >> "$LOGFILE" 2>&1
    fi
    check_exit_status
    shopt -u nullglob

    echo
    echo "** Update database **"
    echo "$(date "+%T") :   - Updatedb" >> "$LOGFILE"
    sudo updatedb
    check_exit_status

    echo
    echo "** Update & Clean v7.0-PLEX Complete **"
    echo "$(date "+%T") :   - Update & Clean Script Complete" >> "$LOGFILE"
}

# --- Self Update Logic (Secured) ---

compare_script_bodies() {
    local file_url="$SCRIPT_URL"
    local temp_file="/tmp/udc_plex_update_check_$$_$(date +%s)"
    
    echo "Checking for script updates..." >> "$LOGFILE"

    if ! wget -q -O "$temp_file" "$file_url"; then
        echo "Failed to download update from $file_url" >> "$LOGFILE"
        rm -f "$temp_file"
        return 1
    fi

    if ! head -n 1 "$temp_file" | grep -q "^#!"; then
        echo "Downloaded file is not a valid script. Aborting update." >> "$LOGFILE"
        rm -f "$temp_file"
        return 1
    fi

    if diff -q "$0" "$temp_file" > /dev/null 2>&1; then
        echo "Script is up to date." >> "$LOGFILE"
        rm -f "$temp_file"
        return 0
    else
        echo "New version detected. Creating backup and updating..." >> "$LOGFILE"
        cp "$0" "${0}.bak.$(date +%s)"
        mv "$temp_file" "$0"
        chmod +x "$0"
        echo "Script updated. Restarting..." >> "$LOGFILE"
        exec "$0" "$@"
        exit 0
    fi
}

# --- Main Execution ---

{
    echo
    echo "==========================================="
    echo "       -:: Update & Clean v7.0-PLEX ::-"
    echo "==========================================="
    echo
    echo "$(date "+%m/%d/%Y @ %T") : ******** Update & Clean Script Started! ********" >> "$LOGFILE"
    echo

    # Check for self-update first
    compare_script_bodies
    check_exit_status

    # Initial apt upgrade
    sudo apt-get upgrade -y
    check_exit_status

    # Run Plex Update FIRST (before general system update to minimize downtime)
    update_plex

    # Run general system update
    update
    
    # Run housekeeping
    housekeeping

    # Reboot check
    if [ -f /var/run/reboot-required ]; then
        echo "$(date "+%T") :   - Maintenance reboot needed, rebooting in 5 minutes" >> "$LOGFILE"
        sudo shutdown -r +5 "Will REBOOT IN 5 due to routine Maintenance"
        check_exit_status
    fi

    echo "$(date "+%m/%d/%Y @ %T") : ******** Update & Clean Script Completed! ********" >> "$LOGFILE"
    echo
    echo "---------------------------"
    echo "          *fin*            "
    echo "---------------------------"
    echo
} 2>> "$ERRORLOG"

exit 0
